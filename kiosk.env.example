# KNIGER Kiosk Konfiguration — Template
# Kopie nach /etc/kiosk/kiosk.env legen, dann befüllen.
# NIEMALS diese Datei mit echten Werten committen!
#
# Vorgehen:
#   sudo cp kiosk.env.example /etc/kiosk/kiosk.env
#   sudo chmod 640 /etc/kiosk/kiosk.env
#   sudo nano /etc/kiosk/kiosk.env

# Eindeutiger Screen-Identifier — muss mit kiosk_screens.screen_key in Supabase übereinstimmen
SCREEN_KEY=kniger-main

# Supabase-Verbindung (nur ANON-Key — niemals Service-Role-Key auf den Pi!)
# Supabase-Projekt: knigercoapp (vtrewducfipnegrlomrx)
SUPABASE_URL=https://vtrewducfipnegrlomrx.supabase.co
SUPABASE_ANON_KEY=

# Kiosk-Token — Fallback, falls kiosk_screens.kiosk_token in Supabase leer ist.
# Primär wird der Token pro Screen aus der DB gelesen (kiosk_screens.kiosk_token).
# Token-Werte auf der cc-vm: cat ~/.kniger/kiosk-token-kiosk1 / kiosk-token-kiosk2
# Niemals committen.
KIOSK_TOKEN=

# Remote-Update: Git-Repo-URL und Branch für automatische Updates
KIOSK_REPO=https://github.com/behrndt/kniger-kiosk.git
KIOSK_BRANCH=main
